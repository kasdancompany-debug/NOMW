# Staff PIN (server-only — preferred)
# Four digits. Verified via POST /api/staff/verify so the value stays off the client bundle
# when this private variable is set in the deployment environment.
STAFF_PIN=2468

# Optional public fallback for air-gapped builds that cannot use private env at runtime.
# WARNING: NEXT_PUBLIC_* values are embedded in the JavaScript bundle and can be extracted.
# Prefer STAFF_PIN. See docs/STAFF_PANEL.md.
# NEXT_PUBLIC_STAFF_PIN=2468

# Optional display version override (defaults to package.json version)
# NEXT_PUBLIC_APP_VERSION=0.1.0

# --- Production Node server (standalone) ---
# Bind address. Use 127.0.0.1 for Option A (local-only). Use 0.0.0.0 for Option B (LAN host).
HOSTNAME=127.0.0.1
PORT=3000

# --- Client / station launch helpers (Windows scripts; not required by Next.js) ---
# Base URL the kiosk browser opens. Option A default shown.
# Option B example: NOMOW_BASE_URL=http://192.168.10.10:3000
NOMOW_BASE_URL=http://127.0.0.1:3000

# Browser binary preference for deploy scripts: edge | chrome
# NOMOW_BROWSER=edge

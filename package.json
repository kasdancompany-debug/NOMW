{
  "name": "northern-ontario-museum-of-wonder",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive touchscreen museum installation for The Northern Ontario Museum of Wonder",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:production": "node scripts/build-production.mjs",
    "pack:deploy": "node scripts/pack-deploy.mjs",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:media": "node scripts/audit-media.mjs",
    "audit:media:strict": "node scripts/audit-media.mjs --strict",
    "audit:scale": "node scripts/audit-silhouette-scale.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "framer-motion": "^12.23.12",
    "howler": "^2.2.4",
